@model CouponDTO

<form asp-action="CouponDelete" method="post">
    <input asp-for="Id" type="hidden" />

    <br />
    <div class="container border p-3">
        <h1 class="text-white text-center">Delete Coupon</h1>

        <hr />
        <div class="row">
            <div class="col-2">
                <label asp-for="Code" class="control-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10 pb-3">
                <input asp-for="Code" class="form-control" disabled />
            </div>
            <div class="col-2">
                <label asp-for="DiscountAmount" class="control-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10 pb-3">
                <input asp-for="DiscountAmount" class="form-control" disabled />
            </div>
            <div class="col-2">
                <label asp-for="MinAmount" class="control-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10 pb-3">
                <input asp-for="MinAmount" class="form-control" disabled />
            </div>
            <div class="col-5 offset-2">
                <a asp-action="CouponIndex" class="btn btn-primary form-control">Back to List</a>
            </div>
            <div class="col-5">
                <input type="submit" value="Delete" class="btn btn-danger form-control" />
            </div>
        </div>
    </div>
</form>
